# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Node dependencies
/node_modules/

# Yarn PnP
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js build output
/.next/
/out/

# Production build
/build/
/dist/

# Local env files (do NOT commit secrets)
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Testing
/coverage/

# TypeScript
*.tsbuildinfo

# IDEs and editors
.idea/
.vscode/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Vercel
.vercel/

# Firebase / GCP service account keys and secrets
*.serviceAccount.json
serviceAccount*.json
*.key
*.pem

# Misc caches
.cache/
.parcel-cache/
.next/cache/

# Turborepo
.turbo/

# pnpm
.pnpm-debug.log

# Optional generated Next types (keep if you want it tracked)
next-env.d.ts
